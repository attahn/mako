// Minimal WASI preview1 example — print + fib (no sockets/TLS).
// Build: mako build examples/wasi_hello.mko --target wasm32-wasi -o out/wasi_hello.wasm
// Run:   wasmtime out/wasi_hello.wasm
fn main() {
    print("hello from mako wasi")
    print_int(fib(10))
}

fn fib(n: int) -> int {
    if n < 2 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}
