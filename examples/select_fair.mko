            print_int(chan_select_value())
        }
        c8 => {
            print_int(8)
            print_int(chan_select_value())
        }
        c9 => {
            print_int(9)
            print_int(chan_select_value())
        }
        default => {
            print("unexpected default")
        }
    }

    select timeout 200 {
        c0 => {
            print_int(0)
            print_int(chan_select_value())
        }
        c1 => {
            print_int(1)
            print_int(chan_select_value())
        }
        c2 => {
            print_int(2)
            print_int(chan_select_value())
        }
        c3 => {
