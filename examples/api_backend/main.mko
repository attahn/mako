// Multi-route JSON API — in-memory notes (POST/GET/DELETE).
// Build: mako build examples/api_backend/main.mko -o out/api_backend
// Curl:
//   curl -sS http://127.0.0.1:18200/health
//   curl -sS -X POST -H 'Content-Type: application/json' \
//        -d '{"title":"hi","body":"world"}' http://127.0.0.1:18200/v1/notes
//   curl -sS http://127.0.0.1:18200/v1/notes
//   curl -sS -X DELETE -H 'X-Note-Key: hi' http://127.0.0.1:18200/v1/notes
// Smoke: ./scripts/api-backend-smoke.sh
// Docs: GUIDE.md "Building APIs"

fn main() {
    let mut max = 40
    if argc() > 1 {
        match parse_int(arg_get(1)) {
            Ok(v) => {
                if v > 0 {
                    max = v
                }
            }
            Err(_) => {}
        }
    }
    let fd = http_bind(18200)
    if fd < 0 {
        print("bind failed")
        return
    }
    print("api_backend on :18200")
    let mut notes = make(map[string]string)
    let mut n = 0
    while n < max {
        let c = http_accept(fd)
        if c < 0 {
            // skip
        } else {
            let method = http_method(c)
            let path = http_path(c)
            let _ctype = http_header(c, "Content-Type")

            if str_eq(path, "/health") {
                let _ = http_respond_json(c, 200, "{\"ok\":true,\"service\":\"api_backend\"}\n")
            } else {
                if str_eq(path, "/v1/notes") {
                    if str_eq(method, "GET") {
                        let body = json_object_from_map_ss(notes)
                        let _ = http_respond_json(c, 200, body)
                    } else {
                        if str_eq(method, "POST") {
                            let raw = http_body(c)
                            let title = json_get_string(raw, "title")
                            let body = json_get_string(raw, "body")
                            if str_eq(title, "") {
                                let _ = http_respond_json(
                                    c,
                                    400,
                                    json_object("error", "title required")
                                )
                            } else {
                                notes[title] = body
                                let resp = json_ss("status", "created", "title", title)
                                let _ = http_respond_json(c, 201, resp)
                            }
                        } else {
                            if str_eq(method, "DELETE") {
                                let key = http_header(c, "X-Note-Key")
                                if str_eq(key, "") {
                                    let _ = http_respond_json(
                                        c,
                                        400,
                                        json_object("error", "X-Note-Key required")
                                    )
                                } else {
                                    delete(notes, key)
                                    let _ = http_respond_json(c, 200, "{\"deleted\":true}\n")
                                }
                            } else {
                                let _ = http_respond_json(
                                    c,
                                    405,
                                    json_object("error", "method not allowed")
                                )
                            }
                        }
                    }
                } else {
                    let _ = http_respond_json(c, 404, json_object("error", "not found"))
                }
            }
            let _ = http_close(c)
            n = n + 1
        }
    }
    let _ = http_close_listener(fd)
    print("api_backend done")
}
