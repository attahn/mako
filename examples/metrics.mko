fn main() {
    metric_inc(0)
    metric_add(0, 4)
    gauge_set(1, 10)
    gauge_add(1, -3)
    hist_observe(2, 100)
    hist_observe(2, 200)

    assert_eq(metric_get(0), 5)
    assert_eq(gauge_get(1), 7)
    assert_eq(hist_count(2), 2)
    assert_eq(hist_sum(2), 300)
    assert_eq(hist_avg(2), 150)

    print(metrics_export())
}
