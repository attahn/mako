// High-res microbench: fib + pre-sized slice fill + pre-sized map.
// Uses now_ns + black_box so -O3/LTO cannot erase kernels.
// Compare: ./scripts/bench-vs-go-rust.sh

fn fib(n: int) -> int {
    if n < 2 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

fn bench_fib() -> int {
    let n = black_box(30)
    let mut acc = 0
    let mut i = 0
    let iters = black_box(5)
    while i < iters {
        acc = acc + fib(n)
        i = i + 1
    }
    return black_box(acc)
}

fn bench_slice() -> int {
    let n = black_box(100000)
    let mut a = make([]int, 0, n)
    let mut i = 0
    while i < n {
        a = append(a, i)
        i = i + 1
    }
    return black_box(len(a))
}

fn bench_map() -> int {
    let n = black_box(50000)
    let mut m = make(map[int]int, n)
    let mut i = 0
    while i < n {
        m[i] = i * 2
        i = i + 1
    }
    let mut sum = 0
    i = 0
    while i < n {
        sum = sum + m[i]
        i = i + 1
    }
    return black_box(sum)
}

fn main() {
    let _ = bench_fib()
    let _ = bench_slice()
    let _ = bench_map()

    let t0 = now_ns()
    let f = bench_fib()
    let t1 = now_ns()
    let s = bench_slice()
    let t2 = now_ns()
    let m = bench_map()
    let t3 = now_ns()

    print("lang")
    print("mako")
    print("fib30x5")
    print_int(f)
    print_int(t1 - t0)
    print("slice100k")
    print_int(s)
    print_int(t2 - t1)
    print("map50k")
    print_int(m)
    print_int(t3 - t2)
}
