fn TestBufPoolGetPut() {
    let mut b = buf_get(32)
    assert_eq(len(b), 0)
    assert(cap(b) >= 32)
    b = append(b, 65)
    b = append(b, 66)
    assert_eq(len(b), 2)
    assert_eq(b[0], 65)
    assert_eq(b[1], 66)
    buf_put(b)
}

fn TestZeroCopyViews() {
    let s = "abcdef"
    let all = as_bytes(s)
    assert_eq(bytes_is_view(all), 1)
    assert_eq_str(bytes_as_str(all), "abcdef")

    let mid = bytes_view(s, 1, 4)
    assert_eq(bytes_is_view(mid), 1)
    assert_eq(len(mid), 3)
    assert_eq_str(bytes_as_str(mid), "bcd")
}
