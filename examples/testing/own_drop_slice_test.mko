// SAFE-003: owning slices free at scope exit; sub-slices are views (shared writes).

fn TestOwnDropSharedView() {
    let mut s = [1, 2, 3]
    let mut t = s[1:3]
    t[0] = 42
    assert_eq(s[1], 42)
    assert_eq(len(t), 2)
}

fn TestOwnDropNestedScope() {
    let mut outer = [10, 20]
    {
        let mut inner = [1, 2, 3]
        inner[0] = 9
        assert_eq(inner[0], 9)
    }
    assert_eq(outer[0], 10)
}

fn TestOwnDropMapSi() {
    let mut m = make(map[string]int)
    m["a"] = 1
    assert_eq(m["a"], 1)
}
