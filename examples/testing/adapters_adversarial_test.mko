// Adversarial memory-safety tests for messaging / GraphQL / gRPC / OpenAPI.
// No GC: every allocate is freeable; double-free paths must be safe; bad ids
// must not crash or leak unbounded.

fn TestMqDoubleFreeAndBadId() {
    let b = mq_new()
    assert(b > 0)
    assert_eq(mq_declare(b, "q", 4), 1)
    assert_eq(mq_publish(b, "q", "x"), 1)
    assert_eq(mq_free(b), 1)
    // Second free / ops on freed id must fail closed (0 / empty), not crash.
    assert_eq(mq_free(b), 0)
    assert_eq(mq_publish(b, "q", "y"), 0)
    assert_eq_str(mq_try_take(b, "q"), "")
    assert_eq(mq_free(0), 0)
    assert_eq(mq_free(-1), 0)
    assert_eq(mq_publish(0, "q", "z"), 0)
}

fn TestMqFullBackpressureNoLeak() {
    let b = mq_new()
    assert_eq(mq_declare(b, "full", 2), 1)
    assert_eq(mq_publish(b, "full", "a"), 1)
    assert_eq(mq_publish(b, "full", "b"), 1)
    // Over-capacity must not grow heap unboundedly.
    assert_eq(mq_publish(b, "full", "c"), 0)
    assert_eq(mq_len(b, "full"), 2)
    assert_eq_str(mq_try_take(b, "full"), "a")
    assert_eq(mq_publish(b, "full", "c"), 1)
    assert_eq(mq_purge(b, "full"), 1)
    assert_eq(mq_len(b, "full"), 0)
    assert_eq(mq_free(b), 1)
}

fn TestNatsStressPublishTake() {
    let n = nats_new()
    assert_eq(nats_sub(n, "s", 32), 1)
    let mut i = 0
    while i < 32 {
        assert_eq(nats_pub(n, "s", "m"), 1)
        i = i + 1
    }
    assert_eq(nats_pub(n, "s", "overflow"), 0)
    assert_eq(nats_len(n, "s"), 32)
    i = 0
    while i < 32 {
        let m = nats_try_next(n, "s")
        assert_eq_str(m, "m")
        i = i + 1
    }
    assert_eq_str(nats_try_next(n, "s"), "")
    assert_eq(nats_free(n), 1)
    assert_eq(nats_free(n), 0)
    assert_eq(nats_free(0), 0)
}

fn TestRedisMqFifoAndFree() {
    let r = redis_mq_new()
    assert_eq(redis_mq_declare(r, "k", 8), 1)
    let mut i = 0
    while i < 8 {
        assert_eq(redis_mq_lpush(r, "k", "x"), 1)
        i = i + 1
    }
    assert_eq(redis_mq_lpush(r, "k", "overflow"), 0)
    i = 0
    while i < 8 {
        assert_eq_str(redis_mq_rpop(r, "k"), "x")
        i = i + 1
    }
    assert_eq_str(redis_mq_rpop(r, "k"), "")
    assert_eq(redis_mq_free(r), 1)
    assert_eq(redis_mq_free(r), 0)
}

fn TestGraphqlSchemaResolveAndFree() {
    let s = graphql_schema_new()
    assert_eq(graphql_schema_add_type(s, "Query"), 1)
    assert_eq(graphql_schema_add_field(s, "Query", "health", "Boolean"), 1)
    assert_eq(graphql_schema_set_resolver(s, "health", "true"), 1)
    // Overwrite resolver (must free previous body).
    assert_eq(graphql_schema_set_resolver(s, "health", "false"), 1)
    let resp = graphql_schema_resolve(s, "{ health }")
    assert(str_contains(resp, "false"))
    // Unresolved field → error JSON, not crash.
    let err = graphql_schema_resolve(s, "{ missing }")
    assert(str_contains(err, "errors") || str_contains(err, "unresolved"))
    assert_eq(graphql_schema_free(s), 1)
    assert_eq(graphql_schema_free(s), 0)
    assert_eq(graphql_schema_free(0), 0)
}

fn TestGrpcServiceDoubleFree() {
    let svc = grpc_service_new("svc.V1")
    assert_eq(grpc_service_add_method(svc, "Ping", "\"pong\""), 1)
    // Overwrite method payload.
    assert_eq(grpc_service_add_method(svc, "Ping", "\"pong2\""), 1)
    let framed = grpc_service_handle(svc, "Ping", "{}")
    assert(len(framed) > 0)
    assert_eq(len(grpc_service_handle(svc, "No", "{}")), 0)
    assert_eq(grpc_service_free(svc), 1)
    assert_eq(grpc_service_free(svc), 0)
    assert_eq(grpc_service_free(0), 0)
}

fn TestOpenApiMergeNoCrash() {
    let a = openapi_route("GET", "/a", "A")
    let b = openapi_route("POST", "/b", "B")
    let m = openapi_paths_merge(a, b)
    assert(str_contains(m, "/a"))
    assert(str_contains(m, "/b"))
    let empty = openapi_paths_merge("{}", "{}")
    assert(str_contains(empty, "{"))
    let info = openapi_info("T", "0.0.1", "d")
    let doc = openapi_doc_full(info, m)
    assert(str_contains(doc, "openapi"))
}

fn TestQueueLangRoundTripAndFree() {
    let q = make(queue[string], 4)
    assert_eq(q.publish("one"), 1)
    assert_eq(q.publish("two"), 1)
    assert_eq(q.len(), 2)
    assert_eq_str(q.try_take(), "one")
    assert_eq(q.purge(), 1)
    assert_eq(q.len(), 0)
    assert_eq(q.free(), 1)
}

fn TestLeakScopeAdapters() {
    // Nestable leak scope: create/destroy brokers inside; exit should report
    // no live delta for these paths (owned payloads transferred/freed).
    let _ = leak_scope_enter()
    let b = mq_new()
    let _ = mq_declare(b, "jobs", 8)
    let _ = mq_publish(b, "jobs", "payload")
    let got = mq_try_take(b, "jobs")
    assert_eq_str(got, "payload")
    let _ = mq_free(b)
    let n = nats_new()
    let _ = nats_sub(n, "t", 4)
    let _ = nats_pub(n, "t", "x")
    let _ = nats_try_next(n, "t")
    let _ = nats_free(n)
    let leaked = leak_scope_exit()
    // leak_scope_exit returns leaked live bytes; 0 is ideal. Some runtimes
    // may count temporary rings — require non-negative and not huge.
    assert(leaked >= 0)
    assert(leaked < 1024 * 1024)
}
