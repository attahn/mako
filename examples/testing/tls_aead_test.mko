fn TestTlsAeadRoundtrip() {
    // AES-128-GCM buffer seal/open (OpenSSL). Not TLS record AEAD / handshake.
    let key = "0123456789abcdef"
    let nonce = "0123456789ab"
    assert_eq(len(key), 16)
    assert_eq(len(nonce), 12)
    let pt = "hello-mako-aead"
    let aad = "mako-aad"
    let sealed = tls_aead_seal(key, nonce, pt, aad)
    assert(len(sealed) >= 16)
    assert(len(sealed) == len(pt) + 16)
    let open = tls_aead_open(key, nonce, sealed, aad)
    assert(str_eq(open, pt))
    // Auth fail on wrong AAD → empty
    assert_eq(len(tls_aead_open(key, nonce, sealed, "wrong")), 0)
    // Auth fail on truncated ciphertext → empty
    assert_eq(len(tls_aead_open(key, nonce, "short", aad)), 0)
}

fn TestTlsRecordAppdata() {
    // TLS 1.3-like application_data record: header + AEAD (AAD = 5-byte header).
    let key = "0123456789abcdef"
    let nonce = "0123456789ab"
    let pt = "app-data"
    let rec = tls_record_appdata_seal(key, nonce, pt)
    assert_eq(tls_record_type(rec), 23)
    assert_eq(tls_record_version(rec), 771)
    assert_eq(tls_record_len(rec), len(pt) + 16)
    assert_eq(len(rec), 5 + len(pt) + 16)
    let open = tls_record_appdata_open(key, nonce, rec)
    assert(str_eq(open, pt))
    assert_eq(len(tls_record_appdata_open(key, "xxxxxxxxxxxx", rec)), 0)
}

fn TestTlsRecordSeqNonce() {
    // Sequence-number GCM nonce: IV XOR seq into last 8 bytes; seal/open increments.
    let key = "0123456789abcdef"
    let iv = "abcdefghijkl"
    assert_eq(len(iv), 12)
    let _ = tls_record_seq_reset()
    assert_eq(tls_record_write_seq(), 0)
    assert_eq(tls_record_read_seq(), 0)
    let r0 = tls_record_appdata_seal_seq(key, iv, "one")
    let r1 = tls_record_appdata_seal_seq(key, iv, "two")
    assert_eq(tls_record_write_seq(), 2)
    assert(not str_eq(r0, r1))
    assert(str_eq(tls_record_appdata_open_seq(key, iv, r0), "one"))
    assert(str_eq(tls_record_appdata_open_seq(key, iv, r1), "two"))
    assert_eq(tls_record_read_seq(), 2)
    // Wrong order / replay with advanced seq → empty
    assert_eq(len(tls_record_appdata_open_seq(key, iv, r0)), 0)
    let _ = tls_record_seq_reset()
}
