fn TestSliceLenCap() {
    let s = [10, 20, 30]
    assert_eq(len(s), 3)
    assert(cap(s) >= 3)
}

fn TestSliceExpr() {
    let s = [1, 2, 3, 4]
    let t = s[1:3]
    assert_eq(len(t), 2)
    assert_eq(t[0], 2)
    assert_eq(t[1], 3)
}

fn TestAppend() {
    let mut s = [1, 2]
    s = append(s, 3)
    assert_eq(len(s), 3)
    assert_eq(s[2], 3)
}

fn TestSharedBacking() {
    let mut s = [1, 2, 3]
    let t = s[1:3]
    t[0] = 42
    assert_eq(s[1], 42)
}
