fn TestByteLitSugar() {
    let b = []byte("ab")
    assert_eq(len(b), 2)
    assert_eq(b[0], 97)
    assert_eq_str(string(b), "ab")
}

fn TestMakeInt() {
    let s = make([]int, 2, 5)
    assert_eq(len(s), 2)
    assert(cap(s) >= 5)
    s[0] = 7
    assert_eq(s[0], 7)
}

fn TestMakeByte() {
    let b = make([]byte, 3)
    assert_eq(len(b), 3)
    assert(cap(b) >= 3)
    b[0] = 1
    b[1] = 2
    assert_eq(b[0] + b[1], 3)
}

fn TestInt8LiteralOk() {
    let x = int8(100)
    assert_eq(int(x), 100)
}
