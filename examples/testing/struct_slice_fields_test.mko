// Structs with slice/map fields must still emit compiling eq/hash helpers.
// (map[Heavy] is rare; identity hash is enough — must not cast arrays to int64.)

struct Heavy {
    n: int
    xs: []int
    m: map[int]int
}

fn TestHeavySliceFieldsCompile() {
    let mut xs = make([]int, 0, 4)
    xs = append(xs, 9)
    let mut m = make(map[int]int)
    m[1] = 2
    let h = Heavy { n: 1, xs: xs, m: m }
    assert_eq(h.n, 1)
    assert_eq(len(h.xs), 1)
    assert_eq(h.xs[0], 9)
    assert_eq(h.m[1], 2)
}

fn TestHeavyMultiReturn() {
    let h, n = make_pair()
    assert_eq(n, 3)
    assert_eq(h.n, 3)
    assert_eq(len(h.xs), 1)
}

fn make_pair() -> (Heavy, int) {
    let mut xs = make([]int, 0, 2)
    xs = append(xs, 1)
    let m = make(map[int]int)
    let h = Heavy { n: 3, xs: xs, m: m }
    return (h, h.n)
}

// Option/Result fields must emit compiling structural eq/hash (not == / cast).
struct WrapOpt {
    o: Option[int]
    t: int
}

struct WrapRes {
    r: Result[int, string]
    n: int
}

fn TestOptionFieldEqHash() {
    let a = WrapOpt { o: Some(1), t: 2 }
    let b = WrapOpt { o: Some(1), t: 2 }
    let c = WrapOpt { o: None, t: 2 }
    assert(a == b)
    assert(a != c)
    // map key with Option field compiles and looks up by structural bag eq
    let mut m = make(map[WrapOpt]int)
    m[a] = 9
    assert_eq(m[b], 9)
    assert(has(m, a))
    assert(not has(m, c))
}

fn TestResultFieldEqHash() {
    let a = WrapRes { r: Ok(3), n: 1 }
    let b = WrapRes { r: Ok(3), n: 1 }
    let c = WrapRes { r: Err("x"), n: 1 }
    assert(a == b)
    assert(a != c)
    let mut m = make(map[WrapRes]int)
    m[a] = 4
    assert_eq(m[b], 4)
}
