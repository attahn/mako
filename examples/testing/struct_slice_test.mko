struct Point {
    x: int
    y: int
}

fn TestStructLitFields() {
    let mut p = Point { x: 3, y: 4 }
    assert_eq(p.x, 3)
    assert_eq(p.y, 4)
    p.x = 10
    assert_eq(p.x, 10)
}

fn TestStructSlice() {
    let mut xs = make([]Point, 0, 2)
    xs = append(xs, Point { x: 1, y: 2 })
    xs = append(xs, Point { x: 5, y: 6 })
    assert_eq(len(xs), 2)
    assert_eq(xs[0].x, 1)
    assert_eq(xs[1].y, 6)
    let lit: []Point = [Point { x: 7, y: 8 }]
    assert_eq(len(lit), 1)
    assert_eq(lit[0].x, 7)
}
