// map[K][][]T — maps with nested-slice values

struct Point {
    x: int
    y: int
}

fn TestMapStringNestedInt() {
    let mut m = make(map[string][][]int)
    m["g"] = [[1, 2], [3]]
    assert_eq(len(m), 1)
    assert_eq(len(m["g"]), 2)
    assert_eq(m["g"][0][0], 1)
    assert_eq(m["g"][0][1], 2)
    assert_eq(m["g"][1][0], 3)
    assert(has(m, "g"))
    assert(not has(m, "z"))
    // missing → empty nested slice
    assert_eq(len(m["missing"]), 0)
    delete(m, "g")
    assert(not has(m, "g"))
}

fn TestMapIntNestedString() {
    let mut m = make(map[int][][]string)
    m[1] = [["a", "b"], ["c"]]
    assert_eq_str(m[1][0][0], "a")
    assert_eq_str(m[1][1][0], "c")
    let v, ok = m[1]
    assert(ok)
    assert_eq(len(v), 2)
}

fn TestMapStructKeyNested() {
    let mut m = make(map[Point][][]int)
    let p = Point { x: 1, y: 2 }
    m[p] = [[9, 8], [7]]
    assert_eq(m[p][0][1], 8)
    assert_eq(m[p][1][0], 7)
}

fn TestMapNestedSliceHelpers() {
    let mut m = make(map[string][][]int)
    m["a"] = [[1, 2]]
    m["b"] = [[3]]
    let ks = maps_keys(m)
    assert_eq(len(ks), 2)
    let vs = maps_values(m)
    assert_eq(len(vs), 2)
    let c = maps_clone(m)
    assert_eq(maps_equal(m, c), 1)
    maps_clear(c)
    assert_eq(len(c), 0)
    maps_copy(c, m)
    assert_eq(len(c), 2)
    assert_eq(c["a"][0][1], 2)
}

fn TestMapNestedSliceRange() {
    let mut m = make(map[string][][]int)
    m["a"] = [[1, 2], [3]]
    m["b"] = [[4]]
    let mut sum = 0
    for _, grid in range m {
        for _, row in range grid {
            for _, v in range row {
                sum = sum + v
            }
        }
    }
    assert_eq(sum, 10)
}

fn TestMapBoolNestedFloat() {
    let mut m = make(map[bool][][]float)
    m[true] = [[1.5], [2.5, 3.5]]
    assert(m[true][0][0] > 1.4)
    assert_eq(len(m[true][1]), 2)
}
