fn TestPathCleanJoin() {
    assert_eq_str(path_clean("/a/b/../c"), "/a/c")
    assert_eq_str(path_clean("a/./b"), "a/b")
    assert_eq_str(path_base("/tmp/x.txt"), "x.txt")
    assert_eq_str(path_dir("/tmp/x.txt"), "/tmp")
    assert_eq_str(path_ext("x.txt"), ".txt")
    assert(path_is_abs("/tmp"))
    assert(!path_is_abs("rel"))
    assert_eq_str(path_join("a", "b"), "a/b")
}

fn TestOsFs() {
    let cwd = getcwd()
    assert(len(cwd) > 0)
    assert(is_dir("."))
    let names = read_dir(".")
    assert(len(names) > 0)
}

fn TestMathCollections() {
    assert_eq(abs(-5), 5)
    assert_eq(min(3, 1), 1)
    assert_eq(max(3, 1), 3)
    assert_eq(clamp(10, 0, 5), 5)
    assert(math_sqrt(9.0) == 3.0)
    assert(math_floor(3.7) == 3.0)
    let sorted = sort_ints([3, 1, 2])
    assert_eq(sorted[0], 1)
    assert(ints_contains(sorted, 2))
    assert_eq(ints_index(sorted, 3), 2)
    let copy = ints_copy(sorted)
    assert_eq(copy[1], 2)
    assert(strings_contains(["b", "a"], "a"))
}

fn TestTimeCryptoHex() {
    let t = now_ms()
    assert(t > 0)
    let s = time_format(t)
    assert(str_contains(s, "T"))
    assert(time_unix() > 0)
    assert_eq_str(hex_encode("AB"), "4142")
    let rb = random_bytes(8)
    assert_eq(len(rb), 8)
    let n = random_int(0, 10)
    assert(n >= 0)
    assert(n < 10)
    let m = mutex_new()
    mutex_lock(m)
    mutex_unlock(m)
}
