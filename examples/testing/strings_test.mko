fn TestStrLenEscapes() {
    assert_eq(len("hi"), 2)
    assert_eq(len("a\nb"), 3)
    assert_eq(len(""), 0)
    assert_eq(str_len("xy"), 2)
}

fn TestStrConcatEq() {
    assert_eq_str("ma" + "ko", "mako")
    assert(str_eq("a", "a"))
    assert("a" != "b")
    assert(str_contains("hello", "ell"))
}

fn TestStrIndexSlice() {
    let s = "hello"
    assert_eq(int(s[0]), 104)
    assert_eq(int(s[4]), 111)
    assert_eq_str(s[1:4], "ell")
    assert_eq_str(s[:2], "he")
    assert_eq_str(s[3:], "lo")
    assert_eq_str(s[:], "hello")
}

fn TestStrUtf8Bytes() {
    // "café" is 5 bytes in UTF-8 (é = 2 bytes), 4 runes
    assert_eq(len("café"), 5)
    assert_eq(rune_count("café"), 4)
}

fn TestStrConvert() {
    let b = []byte("Hi")
    assert_eq(len(b), 2)
    assert_eq_str(string(b), "Hi")
    assert_eq_str(string(7), "7")
    let b2 = bytes("ab")
    assert_eq(b2[0], 97)
}

fn TestStrRangeRunes() {
    // ASCII: rune == byte value
    let mut sum = 0
    for _, r in range "ab" {
        sum = sum + r
    }
    assert_eq(sum, 97 + 98)
    // Multibyte: one iteration per rune; index is byte offset
    let mut n = 0
    let mut last_i = -1
    for i, r in range "café" {
        n = n + 1
        last_i = i
        if r == 233 {
            assert_eq(i, 3)
        }
    }
    assert_eq(n, 4)
    assert_eq(last_i, 3)
}

fn TestWhile() {
    let mut i = 0
    let mut acc = 0
    while i < 4 {
        acc = acc + i
        i = i + 1
    }
    assert_eq(acc, 6)
}

fn TestBreakContinue() {
    let mut sum = 0
    let mut i = 0
    while i < 10 {
        i = i + 1
        if i == 2 {
            continue
        }
        if i == 5 {
            break
        }
        sum = sum + i
    }
    // 1 + 3 + 4 (skipped 2, broke before 5+)
    assert_eq(sum, 8)

    let mut fsum = 0
    for j in range 6 {
        if j == 1 {
            continue
        }
        if j == 4 {
            break
        }
        fsum = fsum + j
    }
    // 0 + 2 + 3
    assert_eq(fsum, 5)
}
