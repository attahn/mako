fn TestDnsAddressHelpers() {
    assert_eq(parse_ip_ok("127.0.0.1"), 1)
    assert_eq(parse_ip_ok("::1"), 1)
    assert_eq(parse_ip_ok("not an ip"), 0)
    assert_eq(dns_ip_family("127.0.0.1"), 4)
    assert_eq(dns_ip_family("::1"), 6)
    assert_eq(dns_ip_family("bad"), 0)

    assert_eq(dns_is_loopback("127.0.0.1"), 1)
    assert_eq(dns_is_loopback("::1"), 1)
    assert_eq(dns_is_loopback("8.8.8.8"), 0)
    assert_eq(dns_is_private("10.1.2.3"), 1)
    assert_eq(dns_is_private("172.16.0.1"), 1)
    assert_eq(dns_is_private("192.168.1.1"), 1)
    assert_eq(dns_is_private("8.8.8.8"), 0)
    assert_eq(dns_is_private("fc00::1"), 1)
    assert_eq(dns_is_private("fe80::1"), 1)
}

fn TestDnsHostPortHelpers() {
    assert_eq_str(dns_normalize_host("  Example.COM  "), "example.com")
    assert_eq_str(dns_normalize_host("[::1]"), "::1")
    assert_eq_str(dns_join_host_port("Example.COM", 443), "example.com:443")
    assert_eq_str(dns_join_host_port("::1", 443), "[::1]:443")
    assert_eq_str(dns_split_host("example.com:443"), "example.com")
    assert_eq(dns_split_port("example.com:443"), 443)
    assert_eq_str(dns_split_host("[::1]:443"), "::1")
    assert_eq(dns_split_port("[::1]:443"), 443)
    assert_eq_str(dns_split_host("::1"), "")
    assert_eq(dns_split_port("example.com"), -1)
    assert_eq(dns_split_port("example.com:99999"), -1)
}

fn TestDnsLookupLocalhost() {
    assert(dns_lookup_count("localhost") >= 1)
    let all = dns_lookup_all("localhost")
    assert(len(all) > 0)
    let first = lookup_host("localhost")
    assert(len(first) > 0)
    let v4 = dns_lookup_ipv4("127.0.0.1")
    assert_eq_str(v4, "127.0.0.1")
    let v6 = dns_lookup_ipv6("::1")
    assert_eq_str(v6, "::1")
}
