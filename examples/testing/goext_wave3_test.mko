fn TestZipStore() {
    let path = "/tmp/mako_zip_wave3.zip"
    assert_eq(zip_write_file(path, "hi.txt", "hello zip"), 0)
    assert_eq_str(zip_first_name(path), "hi.txt")
    assert_eq_str(zip_read_file(path, "hi.txt"), "hello zip")
    let _ = remove_file(path)
}

fn TestPngGrayRoundtrip() {
    if png_available() == 0 {
        return
    }
    // 2x2 grayscale — printable ASCII bytes (Mako string literals lack \x escapes)
    let px = "ABCD"
    let png = png_encode_gray(2, 2, px)
    assert(len(png) > 8)
    assert_eq(png_width(png), 2)
    assert_eq(png_height(png), 2)
    let back = png_decode_gray(png)
    assert_eq(len(back), 4)
    assert_eq_str(back, px)
}

fn TestMapsHelpers() {
    let mut m = make(map[string]int, 4)
    m["a"] = 1
    m["b"] = 2
    let ks = maps_keys(m)
    assert_eq(len(ks), 2)
    let vs = maps_values(m)
    assert_eq(len(vs), 2)
    let c = maps_clone(m)
    assert_eq(maps_equal(m, c), 1)
    maps_clear(c)
    assert_eq(len(maps_keys(c)), 0)
    let mut d = make(map[string]int, 2)
    maps_copy(d, m)
    assert_eq(maps_equal(d, m), 1)
}

fn TestReflectMinimal() {
    assert_eq_str(reflect_type_of_int(42), "int")
    assert_eq_str(reflect_type_of_string("x"), "string")
    assert_eq_str(reflect_kind_of_int(1), "int")
    assert_eq_str(reflect_value_string_int(7), "7")
    assert_eq_str(reflect_value_string_str("ab"), "ab")
    assert_eq(reflect_len_string("abc"), 3)
}

fn TestHttptestGetSoft() {
    // Dead port — empty body / non-200 ok; API must not crash
    let body = httptest_get("http://127.0.0.1:1/")
    assert(len(body) == 0 || len(body) >= 0)
    let _ = httptest_status()
    let _ = httptest_header("Content-Type")
}

fn TestAeadSoft() {
    if aead_available() == 0 {
        assert_eq_str(aes_gcm_seal("0123456789abcdef", "0123456789ab", "hi", ""), "")
        return
    }
    let key16 = "0123456789abcdef"
    let nonce = "0123456789ab"
    let sealed = aes_gcm_seal(key16, nonce, "secret", "aad")
    assert(len(sealed) > 16)
    assert_eq_str(aes_gcm_open(key16, nonce, sealed, "aad"), "secret")
    let key32 = "0123456789abcdef0123456789abcdef"
    let c = chacha20_poly1305_seal(key32, nonce, "chacha", "")
    assert(len(c) > 16)
    assert_eq_str(chacha20_poly1305_open(key32, nonce, c, ""), "chacha")
}

fn TestMultipart() {
    let ct = "multipart/form-data; boundary=----B"
    assert_eq_str(multipart_boundary(ct), "----B")
    let body = "------B\r\nContent-Disposition: form-data; name=\"x\"\r\n\r\nhi\r\n------B--\r\n"
    assert_eq_str(multipart_form_value(body, "----B", "x"), "hi")
}

fn TestRegexpExtras() {
    assert(regex_match("\\d+", "42"))
    assert(regex_match("\\w+", "ab_1"))
    let all = regex_find_all("[0-9]+", "a1b22c", 10)
    assert(len(all) >= 2)
    assert_eq_str(regex_replace("foo", "xfooy", "bar"), "xbary")
    assert_eq_str(regex_replace_all("a", "aba", "z"), "zbz")
}

fn TestWalkDepth() {
    let entries = filepath_walk_n("/tmp", 1)
    assert(len(entries) >= 0)
}
