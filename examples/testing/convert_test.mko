fn TestConvertIntFamily() {
    let a: int = 9
    assert_eq(int64(a), 9)
    assert_eq(int32(a), 9)
    assert_eq(int8(a), 9)
    assert_eq(int(int64(a)), 9)
}

fn TestConvertStringInt() {
    assert_eq_str(string(42), "42")
    assert_eq_str(string(int64(7)), "7")
}

fn TestConvertFloat() {
    let x = float64(3)
    assert_eq(int(x), 3)
    assert_eq(int64(x + float64(1)), 4)
}

fn TestConvertBytes() {
    let b = bytes("xy")
    assert_eq(len(b), 2)
    assert_eq_str(string(b), "xy")
}
