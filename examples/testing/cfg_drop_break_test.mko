// SAFE-006: break/continue free owning locals before leaving the loop body.

fn TestBreakFreesLoopLocal() {
    let mut i = 0
    while i < 10 {
        let mut s = [i, i + 1, i + 2]
        if i == 3 {
            assert_eq(s[0], 3)
            break
        }
        i = i + 1
    }
    assert_eq(i, 3)
}

fn TestContinueFreesLoopLocal() {
    let mut sum = 0
    let mut i = 0
    while i < 5 {
        let mut s = [i]
        i = i + 1
        if s[0] == 2 {
            continue
        }
        sum = sum + s[0]
    }
    // 0+1+3+4 (skipped 2)
    assert_eq(sum, 8)
}
