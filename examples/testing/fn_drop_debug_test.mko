// fn_drop (env free) + debugger/task inspect seeds.

fn apply(f: fn(int) -> int, x: int) -> int {
    return f(x)
}

fn work(n: int) -> int {
    return n * 2
}

fn TestFnDropBare() {
    let f: fn(int) -> int = |x| x + 1
    assert_eq(fn_has_env(f), 0)
    fn_drop(f)
    assert_eq(fn_has_env(f), 0)
}

fn TestFnDropCapturing() {
    let n = 10
    let f: fn(int) -> int = |x| x + n
    assert_eq(fn_has_env(f), 1)
    assert_eq(apply(f, 5), 15)
    fn_drop(f)
    assert_eq(fn_has_env(f), 0)
}

fn TestFnDropStringCapture() {
    let tag = "mako"
    let f: fn(int) -> int = |x| x + len(tag)
    assert_eq(fn_has_env(f), 1)
    assert_eq(f(1), 5)
    fn_drop(f)
    assert_eq(fn_has_env(f), 0)
}

fn TestDebugBreak() {
    let _ = debug_break_reset()
    assert_eq(debug_break_hits(), 0)
    let _ = debug_break("checkpoint-a")
    let _ = debug_break("checkpoint-b")
    assert_eq(debug_break_hits(), 2)
    let _ = debug_break_reset()
    assert_eq(debug_break_hits(), 0)
}

fn TestTaskInspect() {
    runtime_stats_reset()
    crew c {
        let j = c.kick(work(21))
        // While running/registered, id is non-zero.
        assert(task_id(j) > 0)
        let snap = tasks_inspect_json()
        assert(str_contains(snap, "mako.tasks_inspect.v1"))
        assert(str_contains(snap, "tasks"))
        assert_eq(j.join(), 42)
        assert_eq(task_joined(j), 1)
        assert_eq(task_done(j), 1)
    }
    let after = tasks_inspect_json()
    assert(str_contains(after, "tasks_spawned"))
}

// Auto fn_drop on scope exit — no explicit drop required.
fn TestAutoFnDropScope() {
    let n = 7
    let f: fn(int) -> int = |x| x + n
    assert_eq(fn_has_env(f), 1)
    assert_eq(apply(f, 3), 10)
    // scope end drops env; kick moves ownership so no double-free
}

fn TestKickMovesFnEnv() {
    let n = 10
    let f: fn(int) -> int = |x| x + n
    assert_eq(fn_has_env(f), 1)
    crew c {
        let j = c.kick(apply(f, 5))
        // f's env was moved into the task — source is bare after kick.
        assert_eq(fn_has_env(f), 0)
        assert_eq(j.join(), 15)
    }
}

fn TestDebugLocals() {
    assert_eq(debug_set_int("x", 42), 1)
    assert_eq(debug_get_int("x"), 42)
    assert_eq(debug_set_int("y", 7), 1)
    let js = debug_locals_json()
    assert(str_contains(js, "mako.debug_locals.v1"))
    assert(str_contains(js, "\"x\""))
    assert(str_contains(js, "42"))
}

fn TestDebugBp() {
    let _ = debug_break_reset()
    assert_eq(debug_bp_enable(1), 1)
    assert_eq(debug_bp(1), 1) // enabled → hits
    assert_eq(debug_bp(2), 0) // disabled
    assert_eq(debug_bp_disable(1), 1)
    assert_eq(debug_bp(1), 0)
    assert(debug_break_hits() >= 1)
}

fn TestDebugLineBpAndFrames() {
    let _ = debug_break_reset()
    assert_eq(debug_trap_enabled(), 0)
    assert_eq(debug_trap_enable(0), 0) // keep trap off in tests
    let id = debug_line_bp_set("main.mko", 42)
    assert(id >= 0)
    assert_eq(debug_set_loc("main.mko", 42), 1)
    assert(debug_line_bp_hits(id) >= 1)
    assert(debug_break_hits() >= 1)
    assert_eq(debug_line_bp_clear(id), 1)

    assert_eq(debug_frame_depth(), 0)
    assert(debug_push_frame("a.mko", 1, "root") >= 1)
    assert(debug_push_frame("b.mko", 2, "child") >= 2)
    assert_eq(debug_frame_depth(), 2)
    let fj = debug_frames_json()
    assert(str_contains(fj, "mako.debug_frames.v1"))
    assert(str_contains(fj, "child"))
    assert_eq(debug_pop_frame(), 1)
    assert_eq(debug_frame_depth(), 1)
    let _ = debug_pop_frame()

    let snap = debug_snapshot_json()
    assert(str_contains(snap, "mako.debug_snapshot.v1"))
    assert(str_contains(snap, "tasks"))
    assert(str_contains(snap, "locals"))
    assert(str_contains(snap, "frames"))
}

fn TestDebugAsyncParent() {
    // Parent link seed: set current task id, spawn children, inspect parent field.
    let _ = debug_set_current_task(9001)
    assert_eq(debug_current_task(), 9001)
    crew c {
        let j = c.kick(work(2))
        let snap = tasks_inspect_json()
        assert(str_contains(snap, "parent"))
        assert(str_contains(snap, "cancelled"))
        assert_eq(j.join(), 4)
    }
    let _ = debug_set_current_task(0)
}
