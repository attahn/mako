fn TestSlice64() {
    let mut s: []int64 = [1, 2, 3]
    assert_eq(len(s), 3)
    s = append(s, 4)
    assert_eq(len(s), 4)
    assert_eq(s[3], 4)
    let t = s[1:3]
    assert_eq(len(t), 2)
    assert_eq(t[0], 2)
}

fn TestCopy() {
    let src = [10, 20, 30]
    let mut dst = [0, 0]
    let n = copy(dst, src)
    assert_eq(n, 2)
    assert_eq(dst[0], 10)
    assert_eq(dst[1], 20)
}

fn TestCopyPartial() {
    let src = [1]
    let mut dst = [9, 8, 7]
    let n = copy(dst, src)
    assert_eq(n, 1)
    assert_eq(dst[0], 1)
    assert_eq(dst[1], 8)
}

fn TestInt32() {
    let a: int32 = 3
    let b: int32 = 4
    assert_eq(a + b, 7)
    assert_eq(int(a), 3)
}
