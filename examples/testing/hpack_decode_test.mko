// HPACK decode of a real-client request block (Huffman-encoded values + indexed
// names + incremental indexing), as sent by curl/browsers. The bytes below are a
// GET /hello request encoded by a standard HPACK encoder.

fn field(name: string) -> string {
    var i = 0
    let n = hpack_decoded_count()
    for i < n {
        if hpack_decoded_name(i) == name {
            return hpack_decoded_value(i)
        }
        i++
    }
    return ""
}

func TestHpackDecodeRealRequest() {
    // :method GET, :path /hello, :scheme https, :authority localhost:18500,
    // user-agent curl/8.4.0, accept */*  (Huffman where the encoder chose it).
    let block = hex_decode("8244856272d141ff87418ba0e41d139d09b8179b003f7a8825b650c3cbb4b83f5383f963e7")
    let count = hpack_decode_block(block)
    assert_eq(count, 6)
    assert_eq_str(field(":method"), "GET")
    assert_eq_str(field(":path"), "/hello")        // Huffman-decoded
    assert_eq_str(field(":scheme"), "https")
    assert_eq_str(field(":authority"), "localhost:18500")
    assert_eq_str(field("user-agent"), "curl/8.4.0")
    assert_eq_str(field("accept"), "*/*")
    let _ = hpack_decode_clear()
}

// Name-indexed :path literals must use the WIRE value, never static defaults
// (static index 4 = "/", index 5 = "/index.html").
func TestHpackPathLiteralWithoutIndexing() {
    // 0x04 = literal without indexing, name index 4 (:path); value "/docs"
    var b = str_builder()
    builder_write_byte(b, byte(4))
    builder_write_byte(b, byte(5))
    builder_write(b, "/docs")
    assert_eq(hpack_decode_block(builder_string(b)), 1)
    assert_eq_str(field(":path"), "/docs")
    assert(not str_eq(field(":path"), "/"))
    let _ = hpack_decode_clear()
}

func TestHpackPathLiteralIncrementalIndexing() {
    // 0x44 = 68 = literal with incremental indexing, name index 4
    var b = str_builder()
    builder_write_byte(b, byte(68))
    builder_write_byte(b, byte(5))
    builder_write(b, "/book")
    assert_eq(hpack_decode_block(builder_string(b)), 1)
    assert_eq_str(field(":path"), "/book")
    let _ = hpack_decode_clear()
}

func TestHpackPathLiteralNeverIndexed() {
    // 0x14 = 20 = never indexed, name index 4
    var b = str_builder()
    builder_write_byte(b, byte(20))
    builder_write_byte(b, byte(11))
    builder_write(b, "/docs/guide")
    assert_eq(hpack_decode_block(builder_string(b)), 1)
    assert_eq_str(field(":path"), "/docs/guide")
    let _ = hpack_decode_clear()
}

func TestHpackIndexedPathIsSlashOnly() {
    // Fully indexed :path / (0x84) — the only case static "/" is correct
    var b = str_builder()
    builder_write_byte(b, byte(132))
    assert_eq(hpack_decode_block(builder_string(b)), 1)
    assert_eq_str(field(":path"), "/")
    let _ = hpack_decode_clear()
}

func TestHpackCurlStyleDocsRequest() {
    // :method GET, :path /docs (name idx 4), :scheme https, :authority localhost
    var b = str_builder()
    builder_write_byte(b, byte(130)) // :method GET
    builder_write_byte(b, byte(4))   // :path name-indexed without indexing
    builder_write_byte(b, byte(5))
    builder_write(b, "/docs")
    builder_write_byte(b, byte(135)) // :scheme https
    builder_write_byte(b, byte(1))   // :authority name idx 1
    builder_write_byte(b, byte(9))
    builder_write(b, "localhost")
    let n = hpack_decode_block(builder_string(b))
    assert(n >= 3)
    assert_eq_str(field(":method"), "GET")
    assert_eq_str(field(":path"), "/docs")
    assert_eq_str(field(":scheme"), "https")
    let _ = hpack_decode_clear()
}

// Regression: static default for index 4 is "/" — must never replace wire "/docs"
// even when a fully-indexed 0x84 appears later in the same block (false-positive
// for naive byte scanners that return on first 0x84).
func TestHpackPathLiteralNotOverriddenByIndexedSlash() {
    var b = str_builder()
    // :path /docs as literal without indexing
    builder_write_byte(b, byte(4))
    builder_write_byte(b, byte(5))
    builder_write(b, "/docs")
    // trailing fully-indexed :path / (0x84) would poison a byte-scan decoder
    builder_write_byte(b, byte(132))
    assert(hpack_decode_block(builder_string(b)) >= 1)
    // First :path wins for field(); verify it is still the wire literal
    assert_eq_str(field(":path"), "/docs")
    let _ = hpack_decode_clear()
}
