// const fn — compile-time evaluation for sizes and configs.

const fn double(x: int) -> int {
    return x * 2
}

const fn area(w: int, h: int) -> int {
    let a = w * h
    return a
}

const MAX_BUF = double(512)
const TILE = area(16, 16)

fn TestConstFnFold() {
    // Folded at compile time into integer literals
    assert_eq(MAX_BUF, 1024)
    assert_eq(TILE, 256)
    assert_eq(double(21), 42)
    assert_eq(area(3, 7), 21)
}

fn TestConstFnAsArraySize() {
    // Using const values in ordinary arithmetic still works
    let n = MAX_BUF + TILE
    assert_eq(n, 1280)
}

const fn abs_const(x: int) -> int {
    if x < 0 {
        return 0 - x
    } else {
        return x
    }
}

const fn max_const(a: int, b: int) -> int {
    if a >= b {
        return a
    }
    return b
}

const fn clamp_const(x: int, lo: int, hi: int) -> int {
    if x < lo {
        return lo
    } else {
        if x > hi {
            return hi
        } else {
            return x
        }
    }
}

const A_ABS = abs_const(0 - 7)
const A_MAX = max_const(3, 9)
const A_CL = clamp_const(50, 0, 10)

fn TestConstFnIf() {
    assert_eq(A_ABS, 7)
    assert_eq(A_MAX, 9)
    assert_eq(A_CL, 10)
    assert_eq(abs_const(4), 4)
    assert_eq(max_const(1, 2), 2)
    assert_eq(clamp_const(0 - 1, 0, 5), 0)
    // if-expression form
    assert_eq(if 1 < 2 { 10 } else { 20 }, 10)
}

// --- Depth seed: match + while (bounded) ---

const fn classify(n: int) -> int {
    return match n {
        0 => 100,
        1 | 2 => 200,
        _ => -1,
    }
}

const fn sign_const(n: int) -> int {
    return match n {
        0 => 0,
        x => if x > 0 { 1 } else { 0 - 1 },
    }
}

const fn sum_to(n: int) -> int {
    let mut i = 0
    let mut s = 0
    while i < n {
        s = s + i
        i = i + 1
    }
    return s
}

const fn pow2(n: int) -> int {
    let mut i = 0
    let mut p = 1
    while i < n {
        p = p * 2
        i = i + 1
    }
    return p
}

const C_CLASS0 = classify(0)
const C_CLASS1 = classify(1)
const C_CLASS9 = classify(9)
const C_SIGN = sign_const(0 - 5)
const C_SUM = sum_to(5)
const C_POW = pow2(10)

fn TestConstFnMatch() {
    assert_eq(C_CLASS0, 100)
    assert_eq(C_CLASS1, 200)
    assert_eq(classify(2), 200)
    assert_eq(C_CLASS9, -1)
    assert_eq(C_SIGN, 0 - 1)
    assert_eq(sign_const(3), 1)
    assert_eq(sign_const(0), 0)
}

fn TestConstFnWhile() {
    // 0+1+2+3+4 = 10
    assert_eq(C_SUM, 10)
    assert_eq(sum_to(1), 0)
    assert_eq(sum_to(0), 0)
    assert_eq(C_POW, 1024)
    assert_eq(pow2(0), 1)
    assert_eq(pow2(3), 8)
}
