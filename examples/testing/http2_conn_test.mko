fn TestHttp2ConnectionBootstrap() {
    let client = http2_client_preface()
    assert(http2_detect(client))
    assert_eq(http2_frame_type(client), 4)
    assert_eq(http2_settings_len(client), 0)
    let ack = http2_settings_ack()
    assert(http2_is_settings_ack(ack))
    assert(not http2_is_settings_ack(http2_empty_settings()))
    let server = http2_server_preface()
    assert_eq(http2_frame_type(server), 4)
    assert_eq(len(server), 18)
    let second = http2_frame_at(server, 1)
    assert(http2_is_settings_ack(second))
}

fn TestHttp2ConnState() {
    let _ = http2_conn_reset()
    assert_eq(http2_conn_preface_received(), 0)
    assert_eq(http2_conn_settings_exchanged(), 0)
    assert_eq(http2_conn_closing(), 0)
    assert_eq(http2_conn_settings_ack_needed(), 0)
    let _ = http2_conn_recv(http2_client_preface())
    assert_eq(http2_conn_preface_received(), 1)
    // client sent SETTINGS (non-ACK) in preface → ACK needed
    assert_eq(http2_conn_settings_ack_needed(), 1)
    let ack = http2_conn_auto_settings_ack()
    assert(http2_is_settings_ack(ack))
    assert_eq(http2_conn_settings_ack_needed(), 0)
    let _ = http2_conn_send_settings()
    let _ = http2_conn_recv(http2_settings_ack())
    assert_eq(http2_conn_settings_exchanged(), 1)
    let _ = http2_conn_reset()
}

fn TestHttp2ConnGoawayClosing() {
    let _ = http2_conn_reset()
    assert_eq(http2_conn_closing(), 0)
    assert_eq(http2_conn_goaway_last(), -1)
    let g = http2_goaway_frame(0, 0)
    let _ = http2_conn_recv(g)
    assert_eq(http2_conn_closing(), 1)
    assert_eq(http2_conn_goaway_last(), 0)
    // After closing: PING ok, DATA on stream > last rejected
    assert_eq(http2_conn_recv(http2_ping_frame("xxxxxxxx", 0)), 0)
    assert_eq(http2_conn_recv(http2_data_frame(1, "x", 0)), -1)
    let _ = http2_conn_reset()
    assert_eq(http2_conn_closing(), 0)
    let _ = http2_conn_send_goaway()
    assert_eq(http2_conn_closing(), 1)
    let _ = http2_conn_reset()
}

fn TestHttp2ConnGoawayLastStream() {
    let _ = http2_conn_reset()
    // Open stream 1, then GOAWAY last=1
    assert_eq(http2_conn_recv(http2_headers_frame(1, hpack_encode_indexed(2), 4)), 0)
    assert_eq(http2_stream_state_of(1), 1)
    assert_eq(http2_conn_recv(http2_goaway_frame(1, 0)), 0)
    assert_eq(http2_conn_closing(), 1)
    assert_eq(http2_conn_goaway_last(), 1)
    // Existing stream <= last may continue
    assert_eq(http2_conn_recv(http2_data_frame(1, "x", 1)), 0)
    assert_eq(http2_stream_state_of(1), 2)
    // New stream > last rejected (HEADERS open)
    assert_eq(http2_conn_recv(http2_headers_frame(3, hpack_encode_indexed(2), 4)), -1)
    // Pump path also sets closing + last
    let _ = http2_conn_reset()
    let _ = http2_conn_pump(http2_goaway_frame(5, 0))
    assert_eq(http2_conn_closing(), 1)
    assert_eq(http2_conn_goaway_last(), 5)
    let _ = http2_conn_reset()
}

fn TestHttp2ConnRecvStreamSm() {
    let _ = http2_conn_reset()
    assert_eq(http2_stream_state_of(5), 0)
    // HEADERS opens via conn_recv
    let h = http2_headers_frame(5, hpack_encode_indexed(2), 4)
    assert_eq(http2_conn_recv(h), 0)
    assert_eq(http2_stream_state_of(5), 1)
    // DATA END_STREAM → half-closed remote
    assert_eq(http2_conn_recv(http2_data_frame(5, "x", 1)), 0)
    assert_eq(http2_stream_state_of(5), 2)
    assert_eq(http2_stream_half_closed_remote(5), 1)
    // second inbound END_STREAM stays half-closed (need local to close)
    assert_eq(http2_conn_recv(http2_data_frame(5, "", 1)), 0)
    assert_eq(http2_stream_state_of(5), 2)
    // local END_STREAM → closed
    assert_eq(http2_stream_apply_local(http2_data_frame(5, "", 1)), 3)
    assert_eq(http2_stream_state_of(5), 3)
    // RST on fresh stream → closed
    let _ = http2_conn_reset()
    assert_eq(http2_conn_recv(http2_rst_stream_frame(7, 8)), 0)
    assert_eq(http2_stream_state_of(7), 3)
    // HEADERS + END_STREAM alone → open then half-closed remote in one frame
    let _ = http2_conn_reset()
    let hes = http2_headers_frame(9, hpack_encode_indexed(2), 5)
    assert_eq(http2_conn_recv(hes), 0)
    assert_eq(http2_stream_state_of(9), 2)
    assert_eq(http2_stream_half_closed_remote(9), 1)
    // WINDOW_UPDATE on stream via conn_recv
    assert_eq(http2_window_of(9), 65535)
    assert_eq(http2_conn_recv(http2_window_update_frame(9, 100)), 0)
    assert_eq(http2_window_of(9), 65635)
    let _ = http2_conn_reset()
}

fn TestHttp2ConnPump() {
    let _ = http2_conn_reset()
    // Pump client preface: recv SETTINGS + auto ACK
    let ack = http2_conn_pump(http2_client_preface())
    assert(http2_is_settings_ack(ack))
    assert_eq(http2_conn_settings_ack_needed(), 0)
    assert_eq(http2_conn_preface_received(), 1)
    // Pump ACK alone: no outbound ACK owed
    let empty = http2_conn_pump(http2_settings_ack())
    assert_eq(len(empty), 0)
    // Pump error path: orphan CONTINUATION → empty, no crash
    let _ = http2_conn_reset()
    assert_eq(len(http2_conn_pump(http2_continuation_frame(1, "x", 4))), 0)
    let _ = http2_conn_reset()
}

fn TestHttp2ConnPumpPingAck() {
    // Non-ACK PING → pump emits PING ACK with same opaque.
    let _ = http2_conn_reset()
    let ping = http2_ping_frame("pingdata", 0)
    let out = http2_conn_pump(ping)
    assert(http2_is_ping(out))
    assert_eq(http2_frame_flags(out), 1)
    assert_eq(http2_frame_len(out), 8)
    // ACK PING alone → no outbound
    assert_eq(len(http2_conn_pump(http2_ping_frame("pingdata", 1))), 0)
    let _ = http2_conn_reset()
}

fn TestHttp2ConnContinuation() {
    let _ = http2_conn_reset()
    let h = http2_headers_frame(1, "aa", 0)
    let c1 = http2_continuation_frame(1, "bb", 0)
    let c2 = http2_continuation_frame(1, "cc", 4)
    let buf = http2_concat_frames(http2_concat_frames(h, c1), c2)
    assert_eq(http2_conn_recv(buf), 0)
    assert_eq(http2_conn_header_assembling(), 0)
    assert_eq(http2_conn_header_stream(), 1)
    assert(str_eq(http2_conn_header_block(1), "aabbcc"))
    assert_eq(http2_stream_state_of(1), 1)
    // orphan CONTINUATION rejected
    let _ = http2_conn_reset()
    assert_eq(http2_conn_recv(http2_continuation_frame(1, "x", 4)), -1)
    // wrong stream during assembly rejected
    let _ = http2_conn_reset()
    let h2 = http2_headers_frame(3, "x", 0)
    let bad = http2_continuation_frame(5, "y", 4)
    assert_eq(http2_conn_recv(http2_concat_frames(h2, bad)), -1)
    let _ = http2_conn_reset()
}

fn TestHttp2ConnRstAbortsHeaders() {
    // HEADERS without END_HEADERS → assembling; RST on that stream aborts block.
    let _ = http2_conn_reset()
    assert_eq(http2_conn_recv(http2_headers_frame(1, "aa", 0)), 0)
    assert_eq(http2_conn_header_assembling(), 1)
    assert_eq(http2_conn_recv(http2_rst_stream_frame(1, 8)), 0)
    assert_eq(http2_conn_header_assembling(), 0)
    assert_eq(http2_stream_state_of(1), 3)
    // After abort, CONTINUATION is orphan → error
    assert_eq(http2_conn_recv(http2_continuation_frame(1, "bb", 4)), -1)
    let _ = http2_conn_reset()
}

fn TestHttp2MaxConcurrentStreams() {
    // SETTINGS_MAX_CONCURRENT_STREAMS=1 → second open HEADERS rejected.
    let _ = http2_conn_reset()
    assert_eq(http2_conn_max_concurrent(), 0)
    assert_eq(http2_conn_active_streams(), 0)
    assert_eq(http2_conn_recv(http2_settings_max_concurrent(1)), 0)
    assert_eq(http2_conn_max_concurrent(), 1)
    assert_eq(http2_conn_recv(http2_headers_frame(1, hpack_encode_indexed(2), 4)), 0)
    assert_eq(http2_conn_active_streams(), 1)
    assert_eq(http2_stream_state_of(1), 1)
    assert_eq(http2_conn_recv(http2_headers_frame(3, hpack_encode_indexed(2), 4)), -1)
    assert_eq(http2_stream_state_of(3), 0)
    // Close stream 1 → room for stream 3
    assert_eq(http2_conn_recv(http2_rst_stream_frame(1, 8)), 0)
    assert_eq(http2_conn_active_streams(), 0)
    assert_eq(http2_conn_recv(http2_headers_frame(3, hpack_encode_indexed(2), 4)), 0)
    assert_eq(http2_conn_active_streams(), 1)
    let _ = http2_conn_reset()
}

fn TestHttp2StreamIdParity() {
    // Client role (default): odd stream ids only when opening HEADERS.
    let _ = http2_conn_reset()
    assert_eq(http2_conn_is_server(), 0)
    assert_eq(http2_conn_recv(http2_headers_frame(1, hpack_encode_indexed(2), 4)), 0)
    assert_eq(http2_conn_recv(http2_headers_frame(2, hpack_encode_indexed(2), 4)), -1)
    assert_eq(http2_stream_state_of(2), 0)
    // Server role: even stream ids only.
    let _ = http2_conn_reset()
    let _ = http2_conn_set_server(1)
    assert_eq(http2_conn_is_server(), 1)
    assert_eq(http2_conn_recv(http2_headers_frame(2, hpack_encode_indexed(2), 4)), 0)
    assert_eq(http2_conn_recv(http2_headers_frame(1, hpack_encode_indexed(2), 4)), -1)
    assert_eq(http2_stream_state_of(1), 0)
    let _ = http2_conn_reset()
}

fn TestHttp2RejectIdleDataClosedHeaders() {
    // DATA on idle stream rejected.
    let _ = http2_conn_reset()
    assert_eq(http2_conn_recv(http2_data_frame(1, "x", 0)), -1)
    // Open then close via RST; HEADERS on closed rejected.
    assert_eq(http2_conn_recv(http2_headers_frame(1, hpack_encode_indexed(2), 4)), 0)
    assert_eq(http2_conn_recv(http2_rst_stream_frame(1, 8)), 0)
    assert_eq(http2_stream_state_of(1), 3)
    assert_eq(http2_conn_recv(http2_headers_frame(1, hpack_encode_indexed(2), 4)), -1)
    let _ = http2_conn_reset()
}
