fn TestConnPoolStickySlots() {
    let a = conn_pool_slot("tenant-a", 4)
    let b = conn_pool_slot("tenant-a", 4)
    let c = conn_pool_slot("tenant-b", 4)
    assert_eq(a, b)
    assert(a >= 0 && a < 4)
    assert(c >= 0 && c < 4)
    assert_eq(conn_pool_slot("x", 0), -1)
}

fn TestConnPoolRoundRobin() {
    let a = conn_pool_next(3)
    let b = conn_pool_next(3)
    let c = conn_pool_next(3)
    assert(a >= 0 && a < 3)
    assert(b >= 0 && b < 3)
    assert(c >= 0 && c < 3)
    assert_eq(b, (a + 1) % 3)
    assert_eq(c, (b + 1) % 3)
    assert_eq(conn_pool_next(0), -1)
}

fn TestLoadBalancerPickers() {
    let p2 = lb_pick2("a:1", "b:1", "tenant-a")
    assert(str_eq(p2, "a:1") || str_eq(p2, "b:1"))

    let p3 = lb_pick3("a:1", "b:1", "c:1", "tenant-b")
    assert(str_eq(p3, "a:1") || str_eq(p3, "b:1") || str_eq(p3, "c:1"))
    assert_eq_str(lb_pick3("a:1", "b:1", "c:1", "tenant-b"), p3)
}
