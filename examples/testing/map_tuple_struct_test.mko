// map[K](Struct, scalar) / (scalar, Struct) / homogeneous 4-tuples

struct Point {
    x: int
    y: int
}

enum Color {
    Red
    Green
}

fn TestMapStringPointInt() {
    let mut m = make(map[string](Point, int))
    m["a"] = (Point { x: 1, y: 2 }, 3)
    let t = m["a"]
    let p, n = t
    assert_eq(p.x, 1)
    assert_eq(p.y, 2)
    assert_eq(n, 3)
    let z, ok = m["missing"]
    assert(not ok)
    let zp, zn = z
    assert_eq(zp.x, 0)
    assert_eq(zn, 0)
}

fn TestMapIntStringPoint() {
    let mut m = make(map[int](string, Point))
    m[1] = ("hi", Point { x: 4, y: 5 })
    let t = m[1]
    let s, p = t
    assert_eq_str(s, "hi")
    assert_eq(p.x, 4)
    assert_eq(p.y, 5)
}

fn TestMapPointPoint() {
    let mut m = make(map[string](Point, Point))
    m["p"] = (Point { x: 1, y: 1 }, Point { x: 2, y: 2 })
    let t = m["p"]
    let a, b = t
    assert_eq(a.x, 1)
    assert_eq(b.y, 2)
}

fn TestMapEnumInt() {
    let mut m = make(map[string](Color, int))
    m["c"] = (Green, 9)
    let t = m["c"]
    let c, n = t
    assert_eq(n, 9)
    // tag match
    match c {
        Green => assert(true),
        Red => assert(false),
    }
}

fn TestMapStructKeyTupleStruct() {
    let mut m = make(map[Point](Point, int))
    let k = Point { x: 0, y: 0 }
    m[k] = (Point { x: 7, y: 8 }, 1)
    let t = m[k]
    let p, n = t
    assert_eq(p.x, 7)
    assert_eq(n, 1)
}

fn TestMapHomogeneousQuad() {
    let mut m = make(map[string](int, int, int, int))
    m["q"] = (1, 2, 3, 4)
    let t = m["q"]
    let a, b, c, d = t
    assert_eq(a, 1)
    assert_eq(b, 2)
    assert_eq(c, 3)
    assert_eq(d, 4)
}

fn TestMapTupleStructHelpers() {
    let mut m = make(map[string](Point, int))
    m["a"] = (Point { x: 1, y: 2 }, 1)
    m["b"] = (Point { x: 3, y: 4 }, 2)
    let c = maps_clone(m)
    assert_eq(maps_equal(m, c), 1)
    c["a"] = (Point { x: 0, y: 0 }, 0)
    assert_eq(maps_equal(m, c), 0)
    maps_clear(c)
    assert_eq(len(c), 0)
}
