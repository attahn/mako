fn TestRegexSeed() {
    assert(regex_match("^ok$", "ok"))
    assert(not regex_match("^ok$", "no"))
    assert_eq_str(regex_find("ab", "xxabyy"), "ab")
    assert(regex_match("a.c", "abc"))
    assert(not regex_match("a.c", "ac"))
    assert(regex_match("ab*c", "ac"))
    assert(regex_match("ab*c", "abbbc"))
    assert(not regex_match("ab*c", "adc"))
    assert(regex_match("ab+c", "abc"))
    assert(regex_match("ab+c", "abbbc"))
    assert(not regex_match("ab+c", "ac"))
    assert(regex_match("ab?c", "ac"))
    assert(regex_match("ab?c", "abc"))
    assert(not regex_match("ab?c", "abbc"))
    assert(regex_match("cat|dog", "cat"))
    assert(regex_match("cat|dog", "dog"))
    assert(not regex_match("cat|dog", "cow"))
    assert(regex_match("[abc]", "b"))
    assert(not regex_match("[abc]", "d"))
    assert(regex_match("[a-z]+", "hello"))
    assert(not regex_match("[a-z]+", "Hello"))
    assert(regex_match("[^0-9]+", "abc"))
    assert(not regex_match("[^0-9]+", "1"))
    assert(regex_match("(ab)+c", "ababc"))
    assert(not regex_match("(ab)+c", "ac"))
    assert(regex_match("a(b|c)d", "abd"))
    assert(regex_match("a(b|c)d", "acd"))
    assert_eq_str(regex_find("a.*c", "xxabyczz"), "abyc")
    assert_eq_str(regex_find("cat|dog", "xxdogyy"), "dog")
}
