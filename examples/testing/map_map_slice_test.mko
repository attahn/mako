// map[K]map[K2][]T and map[K]map[K2][][]T — nested maps with slice values

struct Point {
    x: int
    y: int
}

fn TestMapStringMapStringIntSlice() {
    let mut outer = make(map[string]map[string][]int)
    let mut mid = make(map[string][]int)
    mid["a"] = [1, 2, 3]
    mid["b"] = [10]
    outer["x"] = mid
    assert_eq(len(outer), 1)
    assert_eq(outer["x"]["a"][0], 1)
    assert_eq(outer["x"]["a"][2], 3)
    assert_eq(outer["x"]["b"][0], 10)
    assert(has(outer, "x"))
    assert(not has(outer, "z"))
    let row, ok = outer["x"]
    assert(ok)
    assert_eq(row["a"][1], 2)
    delete(outer, "x")
    assert(not has(outer, "x"))
}

fn TestMapIntMapIntStringSlice() {
    let mut outer = make(map[int]map[int][]string)
    let mut mid = make(map[int][]string)
    mid[1] = ["hi", "yo"]
    outer[0] = mid
    assert_eq_str(outer[0][1][0], "hi")
    assert_eq_str(outer[0][1][1], "yo")
}

fn TestMapStringMapIntNestedSlice() {
    let mut outer = make(map[string]map[int][][]int)
    let mut mid = make(map[int][][]int)
    mid[1] = [[9, 8], [7]]
    outer["g"] = mid
    assert_eq(outer["g"][1][0][1], 8)
    assert_eq(outer["g"][1][1][0], 7)
}

fn TestMapNamedKeyMapSlice() {
    let mut outer = make(map[Point]map[string][]int)
    let p = Point { x: 1, y: 0 }
    let mut mid = make(map[string][]int)
    mid["n"] = [4, 5]
    outer[p] = mid
    assert_eq(outer[p]["n"][1], 5)
    assert(has(outer, p))
}

fn TestMapMapSliceHelpers() {
    let mut outer = make(map[string]map[string][]int)
    let mut a = make(map[string][]int)
    a["k"] = [1]
    let mut b = make(map[string][]int)
    b["k"] = [2]
    outer["a"] = a
    outer["b"] = b
    let ks = maps_keys(outer)
    assert_eq(len(ks), 2)
    let vs = maps_values(outer)
    assert_eq(len(vs), 2)
    let c = maps_clone(outer)
    assert_eq(maps_equal(outer, c), 1)
    maps_clear(c)
    assert_eq(len(c), 0)
    maps_copy(c, outer)
    assert_eq(len(c), 2)
    assert_eq(c["a"]["k"][0], 1)
}

fn TestMapMapSliceRange() {
    let mut outer = make(map[string]map[string][]int)
    let mut a = make(map[string][]int)
    a["k"] = [1, 2]
    let mut b = make(map[string][]int)
    b["k"] = [3]
    outer["a"] = a
    outer["b"] = b
    let mut sum = 0
    for _, mid in range outer {
        for _, row in range mid {
            for _, v in range row {
                sum = sum + v
            }
        }
    }
    assert_eq(sum, 6)
}

fn TestMapMapSliceCommaOk() {
    let mut outer = make(map[string]map[string][]int)
    let mut mid = make(map[string][]int)
    mid["k"] = [7]
    outer["a"] = mid
    let v, ok = outer["a"]
    assert(ok)
    assert_eq(v["k"][0], 7)
    let _, miss = outer["nope"]
    assert(not miss)
}
