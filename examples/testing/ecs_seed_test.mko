fn TestEcsEntityComponentsAndQueries() {
    let w = ecs_world_new(3)
    assert(w > 0)

    let e1 = ecs_spawn(w)
    let e2 = ecs_spawn(w)
    assert(e1 > 0)
    assert(e2 > 0)
    assert(e1 != e2)
    assert_eq(ecs_alive(w, e1), 1)

    assert_eq(ecs_add(w, e1, 1, 10), 1)
    assert_eq(ecs_add(w, e1, 2, 20), 1)
    assert_eq(ecs_add(w, e2, 1, 30), 1)
    assert_eq(ecs_has(w, e1, 1), 1)
    assert_eq(ecs_has(w, e1, 3), 0)
    assert_eq(ecs_get(w, e1, 1), 10)
    assert_eq(ecs_query_count(w, 1), 2)
    assert_eq(ecs_query_first(w, 1), e1)

    let mask = ecs_archetype(w, e1)
    assert((mask & 2) != 0)
    assert((mask & 4) != 0)
}

fn TestEcsSystemAndRemoval() {
    let w = ecs_world_new(4)
    let a = ecs_spawn(w)
    let b = ecs_spawn(w)
    let c = ecs_spawn(w)

    assert_eq(ecs_add(w, a, 5, 1), 1)
    assert_eq(ecs_add(w, b, 5, 10), 1)
    assert_eq(ecs_add(w, c, 6, 100), 1)
    assert_eq(ecs_system_add(w, 5, 3), 2)
    assert_eq(ecs_get(w, a, 5), 4)
    assert_eq(ecs_get(w, b, 5), 13)
    assert_eq(ecs_get(w, c, 6), 100)

    assert_eq(ecs_set(w, a, 5, 42), 1)
    assert_eq(ecs_get(w, a, 5), 42)
    assert_eq(ecs_remove(w, a, 5), 1)
    assert_eq(ecs_has(w, a, 5), 0)
    assert_eq(ecs_set(w, a, 5, 1), 0)
    assert_eq(ecs_query_count(w, 5), 1)
}

fn TestEcsDespawnAndCapacity() {
    let w = ecs_world_new(2)
    let a = ecs_spawn(w)
    let b = ecs_spawn(w)
    assert_eq(ecs_spawn(w), 0)

    assert_eq(ecs_add(w, a, 1, 7), 1)
    assert_eq(ecs_despawn(w, a), 1)
    assert_eq(ecs_alive(w, a), 0)
    assert_eq(ecs_has(w, a, 1), 0)
    assert_eq(ecs_get(w, a, 1), 0)
    assert_eq(ecs_query_count(w, 1), 0)

    let c = ecs_spawn(w)
    assert_eq(c, a)
    assert_eq(ecs_alive(w, b), 1)
    assert_eq(ecs_world_new(0), 0)
    assert_eq(ecs_add(0, 1, 1, 1), 0)
}
