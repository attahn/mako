// Actor / receive seed with optional owned state (self.fields).

actor Session {
    receive Invite {
        let _ = 1
    }
    receive Timer {
        let _ = 2
    }
    receive Bye {
        let _ = 0
    }
}

actor Counter {
    n: int = 0
    receive Inc {
        self.n = self.n + 1
    }
    receive Bye {
        let _ = 0
    }
}

fn TestActorMailboxLoop() {
    let session = Session_spawn()
    crew t {
        let loopj = t.kick(Session_loop(session))
        assert(Session_send(session, Session_Invite()))
        assert(Session_send(session, Session_Timer()))
        assert(Session_send(session, Session_Bye()))
        assert_eq(loopj.join(), 0)
    }
}

fn TestActorOwnedState() {
    let c = Counter_spawn()
    crew t {
        let loopj = t.kick(Counter_loop(c))
        assert(Counter_send(c, Counter_Inc()))
        assert(Counter_send(c, Counter_Inc()))
        assert(Counter_send(c, Counter_Inc()))
        assert(Counter_send(c, Counter_Bye()))
        // loop returns self.n when field is named n
        assert_eq(loopj.join(), 3)
    }
}

fn TestActorSpawnCap() {
    // Custom mailbox capacity (still int-tag mailbox seed).
    let c = Counter_spawn_cap(32)
    crew t {
        let loopj = t.kick(Counter_loop(c))
        assert(Counter_send(c, Counter_Inc()))
        assert(Counter_send(c, Counter_Bye()))
        assert_eq(loopj.join(), 1)
    }
}

// Int payload seed: receive Inc(delta) packs tag + payload on the mailbox.
actor Accum {
    n: int = 0
    receive Add(delta) {
        self.n = self.n + delta
    }
    receive Set(v: int) {
        self.n = v
    }
    receive Bye {
        let _ = 0
    }
}

fn TestActorIntPayload() {
    let a = Accum_spawn()
    crew t {
        let loopj = t.kick(Accum_loop(a))
        assert(Accum_send(a, Accum_Add(10)))
        assert(Accum_send(a, Accum_Add(5)))
        assert(Accum_send(a, Accum_Set(100)))
        assert(Accum_send(a, Accum_Add(-3)))
        assert(Accum_send(a, Accum_Bye()))
        assert_eq(loopj.join(), 97)
    }
}

fn TestActorPackHelpers() {
    let m = actor_pack(2, 42)
    assert_eq(actor_msg_tag(m), 2)
    assert_eq(actor_msg_payload(m), 42)
    let neg = actor_pack(1, -7)
    assert_eq(actor_msg_payload(neg), -7)
}
