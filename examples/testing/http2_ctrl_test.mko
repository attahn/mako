fn TestHttp2GoawayPingWindow() {
    let g = http2_goaway_frame(3, 0)
    assert(http2_is_goaway(g))
    assert(not http2_is_ping(g))
    assert_eq(http2_frame_type(g), 7)
    assert_eq(http2_frame_stream(g), 0)
    assert_eq(http2_frame_len(g), 8)
    assert_eq(http2_goaway_last_stream(g), 3)
    assert_eq(http2_goaway_error(g), 0)

    let p = http2_ping_frame("pingdata", 0)
    assert(http2_is_ping(p))
    assert_eq(http2_frame_type(p), 6)
    assert_eq(http2_frame_len(p), 8)
    let pack = http2_ping_frame("ack", 1)
    assert_eq(http2_frame_flags(pack), 1)

    let w = http2_window_update_frame(1, 65535)
    assert(http2_is_window_update(w))
    assert_eq(http2_frame_type(w), 8)
    assert_eq(http2_frame_stream(w), 1)
    assert_eq(http2_frame_len(w), 4)
    assert_eq(http2_window_update_increment(w), 65535)
    assert(not http2_is_goaway(w))
}

fn TestHttp2RstPriority() {
    let r = http2_rst_stream_frame(5, 8)
    assert(http2_is_rst_stream(r))
    assert_eq(http2_frame_type(r), 3)
    assert_eq(http2_frame_stream(r), 5)
    assert_eq(http2_frame_len(r), 4)
    assert_eq(http2_rst_stream_error(r), 8)
    assert(not http2_is_priority(r))

    let p = http2_priority_frame(3, 1, 16, 1)
    assert(http2_is_priority(p))
    assert_eq(http2_frame_type(p), 2)
    assert_eq(http2_frame_stream(p), 3)
    assert_eq(http2_frame_len(p), 5)
    assert_eq(http2_priority_dep(p), 1)
    assert_eq(http2_priority_weight(p), 16)
    assert_eq(http2_priority_exclusive(p), 1)

    http2_conn_reset()
    assert_eq(http2_priority_apply(p), 0)
    assert_eq(http2_stream_priority_dep(3), 1)
    assert_eq(http2_stream_priority_weight(3), 16)
    assert_eq(http2_stream_priority_exclusive(3), 1)
    assert_eq(http2_stream_priority_dep(9), -1)
}

fn TestHttp2PriorityTree() {
    http2_conn_reset()
    // 1 and 3 both depend on 0
    assert_eq(http2_priority_apply(http2_priority_frame(1, 0, 16, 0)), 0)
    assert_eq(http2_priority_apply(http2_priority_frame(3, 0, 16, 0)), 0)
    assert_eq(http2_stream_priority_child_count(0), 2)
    assert_eq(http2_stream_priority_dep(1), 0)
    assert_eq(http2_stream_priority_dep(3), 0)
    // exclusive: 5 depends on 0 → former children of 0 reparent under 5
    assert_eq(http2_priority_apply(http2_priority_frame(5, 0, 32, 1)), 0)
    assert_eq(http2_stream_priority_dep(5), 0)
    assert_eq(http2_stream_priority_exclusive(5), 1)
    assert_eq(http2_stream_priority_dep(1), 5)
    assert_eq(http2_stream_priority_dep(3), 5)
    assert_eq(http2_stream_priority_child_count(0), 1)
    assert_eq(http2_stream_priority_child_count(5), 2)
}

fn TestHttp2ConnRecvPriority() {
    // Exclusive PRIORITY via conn_recv (same reparent as priority_apply).
    http2_conn_reset()
    assert_eq(http2_conn_recv(http2_headers_frame(1, hpack_encode_indexed(2), 4)), 0)
    assert_eq(http2_conn_recv(http2_headers_frame(3, hpack_encode_indexed(2), 4)), 0)
    assert_eq(http2_priority_apply(http2_priority_frame(1, 0, 16, 0)), 0)
    assert_eq(http2_priority_apply(http2_priority_frame(3, 0, 16, 0)), 0)
    assert_eq(http2_stream_priority_child_count(0), 2)
    assert_eq(http2_conn_recv(http2_priority_frame(5, 0, 32, 1)), 0)
    assert_eq(http2_stream_priority_dep(5), 0)
    assert_eq(http2_stream_priority_exclusive(5), 1)
    assert_eq(http2_stream_priority_dep(1), 5)
    assert_eq(http2_stream_priority_dep(3), 5)
    assert_eq(http2_stream_priority_child_count(5), 2)
    assert_eq(http2_schedule_next(), 1)
    http2_conn_reset()
}

fn TestHttp2ScheduleNext() {
    http2_conn_reset()
    assert_eq(http2_schedule_next(), -1)
    assert_eq(http2_priority_apply(http2_priority_frame(1, 0, 16, 0)), 0)
    assert_eq(http2_priority_apply(http2_priority_frame(3, 0, 64, 0)), 0)
    assert_eq(http2_priority_apply(http2_priority_frame(5, 0, 32, 0)), 0)
    // same parent (0): highest own weight wins
    assert_eq(http2_schedule_next(), 3)
    // equal weights → lowest stream id
    http2_conn_reset()
    assert_eq(http2_priority_apply(http2_priority_frame(5, 0, 16, 0)), 0)
    assert_eq(http2_priority_apply(http2_priority_frame(1, 0, 16, 0)), 0)
    assert_eq(http2_schedule_next(), 1)
    // tree-aware: child of heavier parent beats heavier root sibling
    // 1→0 w=64, 3→1 w=8, 5→0 w=32; flat max would pick 1; tree picks 3
    http2_conn_reset()
    assert_eq(http2_priority_apply(http2_priority_frame(1, 0, 64, 0)), 0)
    assert_eq(http2_priority_apply(http2_priority_frame(3, 1, 8, 0)), 0)
    assert_eq(http2_priority_apply(http2_priority_frame(5, 0, 32, 0)), 0)
    assert_eq(http2_schedule_next(), 3)
}

fn TestHttp2PushPromise() {
    let pp = http2_push_promise_frame(1, 2, "hdrs", 4)
    assert(http2_is_push_promise(pp))
    assert_eq(http2_frame_type(pp), 5)
    assert_eq(http2_frame_stream(pp), 1)
    assert_eq(http2_frame_len(pp), 8)
    assert_eq(http2_push_promise_stream(pp), 2)
    assert_eq(http2_frame_flags(pp), 4)
}
