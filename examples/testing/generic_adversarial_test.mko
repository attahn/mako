// Adversarial tests for v0.1.9 generics

// --- Generic struct edge cases ---

struct Pair[T] {
    a: T
    b: T
}

struct Box[T] {
    val: T
}

// Same generic instantiated multiple times in one function
fn TestMultipleInstantiations() {
    let p1 = Pair[int] { a: 1, b: 2 }
    let p2 = Pair[string] { a: "x", b: "y" }
    let p3 = Pair[float] { a: 1.0, b: 2.0 }
    assert_eq(p1.a, 1)
    assert_eq_str(p2.a, "x")
}

// Generic struct with default-like values
fn TestGenericZeroValues() {
    let p = Pair[int] { a: 0, b: 0 }
    assert_eq(p.a + p.b, 0)
}

// Nested generic: Box[Pair[int]]
fn TestNestedGenericStruct() {
    let inner = Pair[int] { a: 10, b: 20 }
    let outer = Box[Pair[int]] { val: inner }
    assert_eq(outer.val.a, 10)
    assert_eq(outer.val.b, 20)
}

// Generic function returning generic struct
fn wrap[T](v: T) -> Box[T] {
    return Box[T] { val: v }
}

fn TestGenericFnReturnsGenericStruct() {
    let b = wrap(42)
    assert_eq(b.val, 42)
    let s = wrap("hello")
    assert_eq_str(s.val, "hello")
}

// --- Interface bounds edge cases ---

interface Sized {
    fn size(self) -> int
}

struct Rect {
    w: int
    h: int
}

on Rect {
    fn size(self) -> int {
        return self.w * self.h
    }
}

struct Circle {
    r: int
}

on Circle {
    fn size(self) -> int {
        return self.r * self.r * 3
    }
}

fn get_size[T: Sized](thing: T) -> int {
    return thing.size()
}

fn TestBoundsWithDifferentTypes() {
    let r = Rect { w: 3, h: 4 }
    let c = Circle { r: 5 }
    assert_eq(get_size(r), 12)
    assert_eq(get_size(c), 75)
}

// --- Iterator edge cases ---

struct Counter {
    n: int
    max: int
}

on Counter {
    fn next(self) -> Option[int] {
        if self.n >= self.max {
            return None
        }
        return Some(self.n)
    }
}

fn TestIteratorNextReturnsNone() {
    let c = Counter { n: 5, max: 5 }
    match c.next() {
        Some(_) => assert(false),
        None => assert(true),
    }
}

fn TestIteratorNextReturnsSome() {
    let c = Counter { n: 0, max: 3 }
    match c.next() {
        Some(v) => assert_eq(v, 0),
        None => assert(false),
    }
}

// Multiple generic struct instantiations of same shape
fn TestSameShapeDifferentTypes() {
    let a = Pair[int] { a: 1, b: 2 }
    let b = Pair[int] { a: 3, b: 4 }
    assert_eq(a.a + b.a, 4)
    assert_eq(a.b + b.b, 6)
}

// Passing generic struct to a function
fn sum_pair(p: Pair[int]) -> int {
    return p.a + p.b
}

fn TestGenericStructAsFnParam() {
    let p = Pair[int] { a: 10, b: 20 }
    assert_eq(sum_pair(p), 30)
}
