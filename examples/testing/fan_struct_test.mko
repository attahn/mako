// fan on []Struct via mako_par_map_bytes.

struct Point {
    x: int
    y: int
}

fn TestFanStructScale() {
    let xs = [Point { x: 1, y: 2 }, Point { x: 3, y: 4 }]
    let ys = fan(xs, |p| Point { x: p.x * 10, y: p.y * 10 })
    assert_eq(ys[0].x, 10)
    assert_eq(ys[0].y, 20)
    assert_eq(ys[1].x, 30)
    assert_eq(ys[1].y, 40)
}

fn TestFanStructIdentity() {
    let xs = [Point { x: 7, y: 8 }]
    let ys = fan(xs, |p| p)
    assert_eq(ys[0].x, 7)
    assert_eq(ys[0].y, 8)
}
