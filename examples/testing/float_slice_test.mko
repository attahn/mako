fn TestFloatSliceMake() {
    let mut s = make([]float, 2, 4)
    assert_eq(len(s), 2)
    assert_eq(cap(s), 4)
    s[0] = 1.5
    s[1] = 2.5
    assert(s[0] == 1.5)
    assert(s[1] == 2.5)
    s = append(s, 3.5)
    assert_eq(len(s), 3)
    assert(s[2] == 3.5)
}

fn TestFloatSliceLitRange() {
    let mut xs: []float = [1.0, 2.0, 3.0]
    assert_eq(len(xs), 3)
    let mut n = 0
    for _, v in range xs {
        n = n + 1
        if n == 1 {
            assert(v == 1.0)
        }
    }
    assert_eq(n, 3)
    let t = xs[1:3]
    assert_eq(len(t), 2)
    assert(t[0] == 2.0)
}
