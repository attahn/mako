// Iterator protocol tests — v0.1.9

struct Range {
    current: int
    max: int
}

fn new_range(max: int) -> Range {
    return Range { current: 0, max: max }
}

on Range {
    fn next(self) -> Option[int] {
        if self.current >= self.max {
            return None
        }
        return Some(self.current)
    }
}

fn TestIteratorNext() {
    let r = new_range(3)
    let opt = r.next()
    match opt {
        Some(v) => assert_eq(v, 0),
        None => assert(false),
    }
}

fn TestIteratorManualLoop() {
    let mut r = new_range(5)
    let mut sum = 0
    while r.current < r.max {
        match r.next() {
            Some(v) => {
                sum = sum + v
            },
            None => {},
        }
        r = Range { current: r.current + 1, max: r.max }
    }
    assert_eq(sum, 10)
}

fn TestIteratorTypeCheck() {
    // Verify the type checker accepts struct with next() -> Option[T]
    // as a for-range iterable (even though by-value self limits mutation)
    let r = new_range(1)
    assert_eq(r.max, 1)
}
