// Password hashing — Argon2id (PHC string format), backed by OpenSSL.
// Skips the assertions on platforms where the backend is unavailable.

pull "crypto"

func TestArgon2idRoundTrip() {
    if crypto.password_hashing_ok() == 0 {
        return // backend unavailable — nothing to verify here
    }
    let h = crypto.password_hash("correct horse battery staple")
    assert(len(h) > 0)
    assert_eq(crypto.password_verify(h, "correct horse battery staple"), 1)
    assert_eq(crypto.password_verify(h, "wrong password"), 0)
}

func TestArgon2idUniqueSalt() {
    if crypto.password_hashing_ok() == 0 {
        return
    }
    let a = crypto.password_hash("same")
    let b = crypto.password_hash("same")
    // Different random salts → different encoded hashes.
    assert(not (a == b))
}

func TestArgon2idRejectsGarbage() {
    if crypto.password_hashing_ok() == 0 {
        return
    }
    // A malformed hash must not match and must not crash.
    assert_eq(crypto.password_verify("not-a-valid-hash", "x"), 0)
}
