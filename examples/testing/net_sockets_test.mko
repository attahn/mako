fn TestUdpLoopback() {
    let srv = udp_bind(0)
    if srv >= 0 {
        let port = udp_local_port(srv)
        assert(port > 0)

        let cli = udp_bind(0)
        assert(cli >= 0)
        assert_eq(udp_send_to(cli, "127.0.0.1", port, "ping"), 4)
        let msg = udp_recv(srv, 64)
        assert_eq_str(msg, "ping")

        let _ = udp_close(cli)
        let _ = udp_close(srv)
    }
}

fn TestUnixSocketPair() {
    let a = unix_socket_pair()
    if a >= 0 {
        let b = unix_socket_pair_peer()
        assert(b >= 0)
        assert_eq(unix_write(a, "hello"), 5)
        assert_eq_str(unix_read(b, 64), "hello")
        let _ = unix_close(a)
        let _ = unix_close(b)
    }
}
