fn TestJobScheduleDueAndCancel() {
    let name = "roadmap-job-schedule"
    let due_at = job_schedule(name, 20)
    assert(due_at >= now_ms())
    assert_eq(job_due(name), 0)
    assert(job_delay_ms(name) >= 0)

    sleep_ms(30)
    assert_eq(job_due(name), 1)
    assert_eq(job_delay_ms(name), 0)

    assert_eq(job_cancel(name), 1)
    assert_eq(job_due(name), 0)
    assert_eq(job_delay_ms(name), -1)
    assert_eq(job_cancel(name), 0)
}

fn TestJobScheduleImmediateAndReschedule() {
    let name = "roadmap-job-reschedule"
    assert(job_schedule(name, 0) <= now_ms())
    assert_eq(job_due(name), 1)

    let later = job_schedule(name, 25)
    assert(later >= now_ms())
    assert_eq(job_due(name), 0)
    sleep_ms(35)
    assert_eq(job_due(name), 1)
    assert_eq(job_cancel(name), 1)
}
