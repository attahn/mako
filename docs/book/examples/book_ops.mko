// Book sample — Go-like operators (ch03)
fn main() {
    assert(1 == 1)
    assert(1 != 2)
    assert(2 > 1)
    assert(true && true)
    assert(false || true)
    assert(!false)
    assert(!!true)
    assert_eq(5 & 3, 1)
    assert_eq(5 | 2, 7)
    assert_eq(5 ^ 1, 4)
    assert_eq(5 &^ 1, 4)
    assert_eq(1 << 3, 8)
    assert_eq(16 >> 2, 4)
    let flags = 7
    let mask = 1
    let bits = (flags &^ mask) << 2
    assert_eq(bits, 24)
    print("ops ok")
}
