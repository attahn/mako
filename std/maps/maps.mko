fn keys(m: map[string]int) -> []string { return maps_keys(m) }
fn values(m: map[string]int) -> []int { return maps_values(m) }
fn clear(m: map[string]int) { maps_clear(m) }
fn clone(m: map[string]int) -> map[string]int { return maps_clone(m) }
fn equal(a: map[string]int, b: map[string]int) -> int { return maps_equal(a, b) }
fn copy(dst: map[string]int, src: map[string]int) { maps_copy(dst, src) }
