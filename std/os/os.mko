fn getwd() -> string { return getcwd() }
fn chdir_to(p: string) -> int { return chdir(p) }
fn getenv(k: string) -> string { return env_get(k) }
fn setenv(k: string, v: string) -> int { return env_set(k, v) }
fn exit_with(code: int) { exit(code) }
fn argv() -> []string { return args() }
fn nargs() -> int { return argc() }
